{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build_cpp",
            "type": "shell",
            "command": "/usr/bin/clang++",
            "args": [
                "-std=c++23",
                "-g",
                "-O2",
                "-Wall",
                "-Wextra",
                "-Wno-unused-variable",
                "-Wno-unused-const-variable",
                "-Wno-unused-parameter",
                "\"${file}\"",
                "-o",
                "\"${fileDirname}/${fileBasenameNoExtension}_exe\""
            ],
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "C++ compiler with optimization and warnings"
        },
        {
            "label": "build_C",
            "type": "shell",
            "command": "/usr/bin/clang",
            "args": [
                "-std=c17",
                "-g",
                "-O2",
                "\"${file}\"",
                "-o",
                "\"${fileDirname}/${fileBasenameNoExtension}_exe\""
            ],
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "C compiler with path fix and optimization"
        }
    ]
}